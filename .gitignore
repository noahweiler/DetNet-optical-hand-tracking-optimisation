# Standard Python dev cruft
__pycache__/
*.pyc
*.pyo
*.log

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# ── Model weight tracking policy ────────────────────────────────────────────
# Fine-tuned checkpoints: training produces many per-epoch snapshots
# (ft_*_0.pth, ft_*_1.pth, …), per-run loss/ npy curves, and occasional
# stray baseline copies. The evaluation pipeline only loads the
# best-on-RHD checkpoint per ratio. Ignore EVERYTHING under
# checkpoints_finetuned/, then re-include just the *_rhdbest.pth file
# in each ratio subdir.
checkpoints_finetuned/**
!checkpoints_finetuned/
!checkpoints_finetuned/*/
!checkpoints_finetuned/*/ft_*_rhdbest.pth

# Baseline DetNet folder: track ONLY the epoch-71 checkpoint used as
# the reference baseline throughout the thesis. Other epochs and the
# unused SikNet / BMC checkpoints stay out of git.
new_check_point/*.pth
!new_check_point/ckp_detnet_71.pth
